            "arguments": "{\"command\":\"python - <<'PY'\\nfrom pathlib import Path\\nfrom html.parser import HTMLParser\\nimport re, json, xml.etree.ElementTree as ET\\nroot=Path('.')\\narticle=root/'artikel/palworld-server-hosting-guide-2026.html'\\nindex=root/'index.html'\\nsitemap=root/'sitemap.xml'\\nerrors=[]\\nclass TextExtractor(HTMLParser):\\n    def __init__(self):\\n        super().__init__(); self.text=[]; self.in_script=False; self.in_style=False\\n    def handle_starttag(self, tag, attrs):\\n        if tag=='script': self.in_script=True\\n        if tag=='style': self.in_style=True\\n    def handle_endtag(self, tag):\\n        if tag=='script': self.in_script=False\\n        if tag=='style': self.in_style=False\\n    def handle_data(self, data):\\n        if not self.in_script and not self.in_style: self.text.append(data)\\nhtml=article.read_text(encoding='utf-8')\\nfor needle in [\\n    'rel=\\\"canonical\\\" href=\\\"https://hostazar.com/artikel/palworld-server-hosting-guide-2026.html\\\"',\\n    'property=\\\"og:type\\\" content=\\\"article\\\"',\\n    'property=\\\"og:title\\\" content=\\\"Palworld Server mieten oder selbst hosten? Der komplette Hosting-Guide 2026\\\"',\\n    'property=\\\"og:image\\\" content=\\\"https://hostazar.com/images/palworld-server-hosting-guide-2026.png\\\"',\\n    '15. Juni 2026', 'Google AdSense Platzhalter', 'tag=nova079-20', 'BlogPosting'\\n]:\\n    if needle not in html: errors.append('missing article needle: '+needle)\\nparser=TextExtractor(); parser.feed(html)\\nwords=re.findall(r\\\"[A-Za-zÄÖÜäöüß0-9][A-Za-zÄÖÜäöüß0-9\\\\-–]+\\\", ' '.join(parser.text))\\nword_count=len(words)\\nif not 1500 <= word_count <= 2200: errors.append(f'word count outside range: {word_count}')\\njson_ok=False\\nfor m in re.finditer(r'<script type=\\\"application/ld\\\\+json\\\">\\\\s*(.*?)\\\\s*</script>', html, flags=re.S):\\n    data=json.loads(m.group(1))\\n    if isinstance(data, dict) and data.get('@type')=='BlogPosting':\\n        json_ok=True\\n        if data.get('datePublished')!='2026-06-15': errors.append('bad datePublished')\\n        if data.get('image')!='https://hostazar.com/images/palworld-server-hosting-guide-2026.png': errors.append('bad json image')\\nif not json_ok: errors.append('no article BlogPosting JSON-LD parsed')\\nidx=index.read_text(encoding='utf-8')\\nif idx.count('/artikel/palworld-server-hosting-guide-2026.html') < 3:\\n    errors.append('index link/card/json missing or too few occurrences')\\nfor m in re.finditer(r'<script type=\\\"application/ld\\\\+json\\\">\\\\s*(.*?)\\\\s*</script>', idx, flags=re.S):\\n    data=json.loads(m.group(1))\\n    if isinstance(data, list):\\n        if not any(isinstance(x,dict) and x.get('url')=='https://hostazar.com/artikel/palworld-server-hosting-guide-2026.html' for x in data):\\n            errors.append('homepage BlogPosting JSON-LD lacks Palworld')\\nET.parse(sitemap)\\nsmap=sitemap.read_text(encoding='utf-8')\\nif 'https://hostazar.com/artikel/palworld-server-hosting-guide-2026.html' not in smap:\\n    errors.append('sitemap missing Palworld URL')\\n# Check local relative and root asset links\\nlinks=re.findall(r'(?:href|src)=\\\"([^\\\"]+)\\\"', html + '\\\\n' + idx)\\nmissing=[]\\nfor href in links:\\n    if href.startswith(('http://','https://','mailto:','#')):\\n        continue\\n    if href.startswith('/'):\\n        target=(root/href.lstrip('/')).resolve()\\n    else:\\n        base=article.parent if href in re.findall(r'(?:href|src)=\\\"([^\\\"]+)\\\"', html) else root\\n        target=(base/href).resolve()\\n    if not target.exists():\\n        # anchors like /#gaming are not real files but are okay\\n        if href.startswith('/#') or href == '#':\\n            continue\\n        missing.append(href)\\nif missing: errors.append('missing links/assets: '+', '.join(sorted(set(missing))))\\nfor p in ['images/palworld-server-hosting-guide-2026.png','images/icon_palworld-server-hosting-guide-2026.png']:\\n    if not (root/p).exists() or (root/p).stat().st_size < 1000: errors.append('image missing/small: '+p)\\nprint(f'article_word_count={word_count}')\\nprint(f'article_amazon_tag_count={html.count('tag=nova079-20')}')\\nprint(f'index_occurrences={idx.count('/artikel/palworld-server-hosting-guide-2026.html')}')\\nprint('sitemap_xml=parse_ok')\\nprint('images=ok')\\nif errors:\\n    print('VERIFY_ERRORS')\\n    for e in errors: print('-', e)\\n    raise SystemExit(1)\\nprint('VERIFY_OK')\\nPY\\nprintf '\\\\n--- git diff --check ---\\\\n'\\ngit diff --check -- artikel/palworld-server-hosting-guide-2026.html index.html sitemap.xml images/palworld-server-hosting-guide-2026.png images/icon_palworld-server-hosting-guide-2026.png\\nprintf '\\\\n--- git status --short ---\\\\n'\\ngit status --short\\nprintf '\\\\n--- git diff --stat ---\\\\n'\\ngit diff --stat -- artikel/palworld-server-hosting-guide-2026.html index.html sitemap.xml images/palworld-server-hosting-guide-2026.png images/icon_palworld-server-hosting-guide-2026.png\",\"timeout\":120,\"workdir\":\"/c/HermesPortable/home/tmp/hostazar-palworld-work\"}"
