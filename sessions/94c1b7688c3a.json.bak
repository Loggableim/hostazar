      "name": "read_file",
      "content": "{\"content\": \"     1|#!/usr/bin/env python3\\n     2|\\\"\\\"\\\"\\n     3|Pop-Tech Kacheln Batch Generator für hostazar.com\\n     4|Generiert alle Artikel-Bilder im Pop-Tech Kacheln Stil via ComfyUI SDXL + Pillow-Textoverlay.\\n     5|\\\"\\\"\\\"\\n     6|import json, urllib.request, time, os, sys\\n     7|from PIL import Image, ImageDraw, ImageFont\\n     8|\\n     9|# Konfiguration\\n    10|COMFY_URL = \\\"http://127.0.0.1:8188\\\"\\n    11|OUTPUT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), \\\"..\\\", \\\"images\\\"))\\n    12|os.makedirs(OUTPUT_DIR, exist_ok=True)\\n    13|\\n    14|# Artikel-Definitionen\\n    15|ARTICLES = [\\n    16|    {\\n    17|        \\\"slug\\\": \\\"vps-absichern-2026\\\",\\n    18|        \\\"title\\\": \\\"VPS absichern 2026\\\",\\n    19|        \\\"category\\\": \\\"devops\\\",\\n    20|        \\\"color\\\": \\\"#FF9800\\\",\\n    21|        \\\"icon_prompt\\\": \\\"a shield with a lock inside, flat bold vector icon, white silhouette, minimalist, centered on dark background, security symbol, no details, clean shape\\\"\\n    22|    },\\n    23|    {\\n    24|        \\\"slug\\\": \\\"docker-compose-vps-guide\\\",\\n    25|        \\\"title\\\": \\\"Docker Compose auf dem VPS\\\",\\n    26|        \\\"category\\\": \\\"devops\\\",\\n    27|        \\\"color\\\": \\\"#FF9800\\\",\\n    28|        \\\"icon_prompt\\\": \\\"three stacked server boxes or containers, flat bold vector icon, white silhouette, minimalist, centered on dark background, docker style, no details\\\"\\n    29|    },\\n    30|    {\\n    31|        \\\"slug\\\": \\\"valheim-server-vps-mieten-2026\\\",\\n    32|        \\\"title\\\": \\\"Valheim Server mieten\\\",\\n    33|        \\\"category\\\": \\\"gaming\\\",\\n    34|        \\\"color\\\": \\\"#4CAF50\\\",\\n    35|        \\\"icon_prompt\\\": \\\"a viking helmet with horns, flat bold vector icon, white silhouette, minimalist, centered on dark background, norse symbol, no details\\\"\\n    36|    },\\n    37|    {\\n    38|        \\\"slug\\\": \\\"webhosting-anbieter-vergleich-2026\\\",\\n    39|        \\\"title\\\": \\\"Webhosting-Anbieter 2026\\\",\\n    40|        \\\"category\\\": \\\"webhosting\\\",\\n    41|        \\\"color\\\": \\\"#2196F3\\\",\\n    42|        \\\"icon_prompt\\\": \\\"a globe or world wide web symbol, flat bold vector icon, white silhouette, minimalist, centered on dark background, internet, clean shape\\\"\\n    43|    },\\n    44|    {\\n    45|        \\\"slug\\\": \\\"minecraft-server-vergleich-2026\\\",\\n    46|        \\\"title\\\": \\\"Minecraft Server\\\",\\n    47|        \\\"category\\\": \\\"gaming\\\",\\n    48|        \\\"color\\\": \\\"#4CAF50\\\",\\n    49|        \\\"icon_prompt\\\": \\\"a pickaxe crossed with a sword, flat bold vector icon, white silhouette, minimalist, centered on dark background, minecraft style, no details\\\"\\n    50|    },\\n    51|    {\\n    52|        \\\"slug\\\": \\\"gameserver-mieten-guide\\\",\\n    53|        \\\"title\\\": \\\"Gameserver mieten\\\",\\n    54|        \\\"category\\\": \\\"gaming\\\",\\n    55|        \\\"color\\\": \\\"#4CAF50\\\",\\n    56|        \\\"icon_prompt\\\": \\\"a game controller or gamepad, flat bold vector icon, white silhouette, minimalist, centered on dark background, gaming symbol, no details\\\"\\n    57|    },\\n    58|    {\\n    59|        \\\"slug\\\": \\\"webhosting-vserver-vergleich\\\",\\n    60|        \\\"title\\\": \\\"Webhosting vs VServer\\\",\\n    61|        \\\"category\\\": \\\"webhosting\\\",\\n    62|        \\\"color\\\": \\\"#2196F3\\\",\\n    63|        \\\"icon_prompt\\\": \\\"a balance scale or two servers side by side, flat bold vector icon, white silhouette, minimalist, centered on dark background, comparison symbol\\\"\\n    64|    },\\n    65|    {\\n    66|        \\\"slug\\\": \\\"devops-tools-2024\\\",\\n    67|        \\\"title\\\": \\\"DevOps Tools 2024\\\",\\n    68|        \\\"category\\\": \\\"devops\\\",\\n    69|        \\\"color\\\": \\\"#FF9800\\\",\\n    70|        \\\"icon_prompt\\\": \\\"a gear or wrench crossed with a terminal bracket, flat bold vector icon, white silhouette, minimalist, centered on dark background, tools symbol\\\"\\n    71|    },\\n    72|]\\n    73|\\n    74|CATEGORY_COLORS = {\\n    75|    \\\"gaming\\\": (\\\"#4CAF50\\\", \\\"#81C784\\\"),\\n    76|    \\\"webhosting\\\": (\\\"#2196F3\\\", \\\"#64B5F6\\\"),\\n    77|    \\\"devops\\\": (\\\"#FF9800\\\", \\\"#FFB74D\\\"),\\n    78|}\\n    79|\\n    80|def parse_hex(h):\\n    81|    h = h.lstrip(\\\"#\\\")\\n    82|    return tuple(int(h[i:i+2], 16) for i in (0, 2, 4))\\n    83|\\n    84|def hex_to_rgb(h):\\n    85|    return parse_hex(h)\\n    86|\\n    87|def submit_sdxl_prompt(prompt_text, width=1216, height=640):\\n    88|    \\\"\\\"\\\"Submit SDXL prompt to ComfyUI and return prompt_id.\\\"\\\"\\\"\\n    89|    workflow = {\\n    90|        \\\"1\\\": {\\n    91|            \\\"class_type\\\": \\\"CheckpointLoaderSimple\\\",\\n    92|            \\\"inputs\\\": {\\\"ckpt_name\\\": \\\"sd_xl_base_1.0.safetensors\\\"}\\n    93|        },\\n    94|        \\\"2\\\": {\\n    95|            \\\"class_type\\\": \\\"CLIPTextEncode\\\",\\n    96|            \\\"inputs\\\": {\\n    97|                \\\"text\\\": prompt_text,\\n    98|                \\\"clip\\\": [\\\"1\\\", 1]\\n    99|            }\\n   100|        },\\n   101|        \\\"3\\\": {\\n   102|            \\\"class_type\\\": \\\"CLIPTextEncode\\\",\\n   103|            \\\"inputs\\\": {\\n   104|                \\\"text\\\": \\\"text, watermark, signature, blurry, low quality, distorted, ugly, deformed, photorealistic, gradient, detailed, noisy, complex\\\",\\n   105|                \\\"clip\\\": [\\\"1\\\", 1]\\n   106|            }\\n   107|        },\\n   108|        \\\"4\\\": {\\n   109|            \\\"class_type\\\": \\\"EmptyLatentImage\\\",\\n   110|            \\\"inputs\\\": {\\n   111|                \\\"width\\\": width,\\n   112|                \\\"height\\\": height,\\n   113|                \\\"batch_size\\\": 1\\n   114|            }\\n   115|        },\\n   116|        \\\"5\\\": {\\n   117|            \\\"class_type\\\": \\\"KSampler\\\",\\n   118|            \\\"inputs\\\": {\\n   119|                \\\"seed\\\": 42,\\n   120|                \\\"control_after_generate\\\": \\\"randomize\\\",\\n   121|                \\\"steps\\\": 25,\\n   122|                \\\"cfg\\\": 7.0,\\n   123|                \\\"sampler_name\\\": \\\"dpmpp_2m\\\",\\n   124|                \\\"scheduler\\\": \\\"karras\\\",\\n   125|                \\\"denoise\\\": 1.0,\\n   126|                \\\"model\\\": [\\\"1\\\", 0],\\n   127|                \\\"positive\\\": [\\\"2\\\", 0],\\n   128|                \\\"negative\\\": [\\\"3\\\", 0],\\n   129|                \\\"latent_image\\\": [\\\"4\\\", 0]\\n   130|            }\\n   131|        },\\n   132|        \\\"6\\\": {\\n   133|            \\\"class_type\\\": \\\"VAEDecode\\\",\\n   134|            \\\"inputs\\\": {\\n   135|                \\\"samples\\\": [\\\"5\\\", 0],\\n   136|                \\\"vae\\\": [\\\"1\\\", 2]\\n   137|            }\\n   138|        },\\n   139|        \\\"7\\\": {\\n   140|            \\\"class_type\\\": \\\"SaveImage\\\",\\n   141|            \\\"inputs\\\": {\\n   142|                \\\"filename_prefix\\\": \\\"poptech_temp\\\",\\n   143|                \\\"images\\\": [\\\"6\\\", 0]\\n   144|            }\\n   145|        }\\n   146|    }\\n   147|    payload = json.dumps({\\\"prompt\\\": workflow, \\\"client_id\\\": \\\"hostazar-poptech\\\"}).encode()\\n   148|    req = urllib.request.Request(\\n   149|        f\\\"{COMFY_URL}/prompt\\\",\\n   150|        data=payload,\\n   151|        headers={\\\"Content-Type\\\": \\\"application/json\\\"}\\n   152|    )\\n   153|    resp = json.loads(urllib.request.urlopen(req).read())\\n   154|    pid = resp[\\\"prompt_id\\\"]\\n   155|    print(f\\\"  Prompt submitted: {pid}\\\")\\n   156|    return pid\\n   157|\\n   158|def poll_history(prompt_id, timeout=180):\\n   159|    \\\"\\\"\\\"Poll ComfyUI history until prompt completes.\\\"\\\"\\\"\\n   160|    start = time.time()\\n   161|    while time.time() - start < timeout:\\n   162|        try:\\n   163|            req = urllib.request.Request(f\\\"{COMFY_URL}/history/{prompt_id}\\\")\\n   164|            hist = json.loads(urllib.request.urlopen(req).read())\\n   165|            if prompt_id in hist:\\n   166|                entry = hist[prompt_id]\\n   167|                status = entry.get(\\\"status\\\", {})\\n   168|                if status.get(\\\"completed\\\") or status.get(\\\"status_str\\\") == \\\"success\\\":\\n   169|                    return entry\\n   170|                if status.get(\\\"status_str\\\") == \\\"error\\\":\\n   171|                    msgs = status.get(\\\"messages\\\", [])\\n   172|                    for mt, m in msgs:\\n   173|                        if mt == \\\"execution_error\\\":\\n   174|                            print(f\\\"  ERROR: {m.get('exception_message', 'unknown')}\\\")\\n   175|                    return None\\n   176|        except Exception as e:\\n   177|            pass  # still running\\n   178|        time.sleep(3)\\n   179|    print(f\\\"  TIMEOUT after {timeout}s\\\")\\n   180|    return None\\n   181|\\n   182|def download_image(filename, subfolder=\\\"\\\", output_path=None):\\n   183|    \\\"\\\"\\\"Download a generated image from ComfyUI output.\\\"\\\"\\\"\\n   184|    params = urllib.parse.urlencode({\\n   185|        \\\"filename\\\": filename,\\n   186|        \\\"subfolder\\\": subfolder,\\n   187|        \\\"type\\\": \\\"output\\\"\\n   188|    })\\n   189|    url = f\\\"{COMFY_URL}/view?{params}\\\"\\n   190|    if output_path is None:\\n   191|        output_path = os.path.join(OUTPUT_DIR, filename)\\n   192|    urllib.request.urlretrieve(url, output_path)\\n   193|    return output_path\\n   194|\\n   195|def get_latest_output(history_entry):\\n   196|    \\\"\\\"\\\"Get the output image filename from a history entry.\\\"\\\"\\\"\\n   197|    outputs = history_entry.get(\\\"outputs\\\", {})\\n   198|    for node_id, node_out in outputs.items():\\n   199|        images = node_out.get(\\\"images\\\", [])\\n   200|        if images:\\n   201|            img = images[0]\\n   202|            return img[\\\"filename\\\"], img.get(\\\"subfolder\\\", \\\"\\\")\\n   203|    return None, None\\n   204|\\n   205|def compose_poptech(icon_path, output_path, title_text, category):\\n   206|    \\\"\\\"\\\"Compose the final Pop-Tech Kacheln image with background, icon, and text.\\\"\\\"\\\"\\n   207|    # Size\\n   208|    W, H = 1200, 630\\n   209|\\n   210|    # Colors\\n   211|    if category in CATEGORY_COLORS:\\n   212|        left_color_hex, left_color_light = CATEGORY_COLORS[category]\\n   213|    else:\\n   214|        left_color_hex, left_color_light = \\\"#9C27B0\\\", \\\"#CE93D8\\\"\\n   215|    purple = \\\"#9C27B0\\\"\\n   216|    left_rgb = hex_to_rgb(left_color_hex)\\n   217|    purple_rgb = hex_to_rgb(purple)\\n   218|\\n   219|    # Create canvas\\n   220|    canvas = Image.new(\\\"RGB\\\", (W, H))\\n   221|\", \"total_lines\": 389, \"file_size\": 15705, \"truncated\": true, \"hint\": \"Use offset=221 to continue reading (showing 1-220 of 389 lines)\", \"is_binary\": false, \"is_image\": false}",
