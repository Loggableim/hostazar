            "name": "terminal",
            "arguments": "{\"command\":\"python - <<'PY'\\nfrom pathlib import Path\\nfrom PIL import Image, ImageDraw, ImageFont\\nimport importlib.util, sys\\nroot=Path('.')\\nimg_dir=root/'images'\\nslug='palworld-server-hosting-guide-2026'\\nicon_path=img_dir/f'icon_{slug}.png'\\n# deterministic flat icon: server cube + paw/orb silhouette on dark background\\nS=1024\\nicon=Image.new('RGB',(S,S),'#222222')\\nd=ImageDraw.Draw(icon)\\nwhite=(255,255,255)\\n# server rack/body\\nx0,y0,x1,y1=270,300,754,650\\nd.rounded_rectangle([x0,y0,x1,y1], radius=42, outline=white, width=34)\\nfor y in [390,510]:\\n    d.line([x0+40,y,x1-40,y], fill=white, width=24)\\nfor y in [345,465,585]:\\n    d.ellipse([x0+52,y-16,x0+84,y+16], fill=white)\\n    d.rounded_rectangle([x0+120,y-13,x1-60,y+13], radius=13, fill=white)\\n# pal/paw motif above\\ncx,cy=512,235\\nd.ellipse([cx-82,cy-48,cx+82,cy+116], outline=white, width=34)\\nfor px,py,r in [(410,190,34),(475,145,32),(546,145,32),(615,190,34)]:\\n    d.ellipse([px-r,py-r,px+r,py+r], fill=white)\\n# small network lines\\nfor x in [400,512,624]:\\n    d.line([x,670,x,760], fill=white, width=22)\\n    d.ellipse([x-28,744,x+28,800], fill=white)\\nicon.save(icon_path)\\n# compose final in existing Pop-Tech style\\nspec=importlib.util.spec_from_file_location('poptech', str(root/'scripts/poptech_batch.py'))\\nmod=importlib.util.module_from_spec(spec); spec.loader.exec_module(mod)\\nmod.compose_poptech(str(icon_path), str(img_dir/f'{slug}.png'), 'Palworld Server Hosting', 'gaming')\\nprint(icon_path)\\nprint(img_dir/f'{slug}.png')\\nPY\\nfile images/palworld-server-hosting-guide-2026.png images/icon_palworld-server-hosting-guide-2026.png\",\"timeout\":120,\"workdir\":\"/c/HermesPortable/home/tmp/hostazar-palworld-work\"}"
