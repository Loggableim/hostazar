      "name": "read_file",
      "snippet": "{\"content\": \"     1|#!/usr/bin/env python3\\n     2|\\\"\\\"\\\"\\n     3|Pop-Tech Kacheln Batch Generator für hostazar.com\\n     4|Generiert alle Artikel-Bilder im Pop-Tech Kacheln Stil via ComfyUI SDXL + Pillow-Textoverlay.\\n     5|\\\"\\\"\\\"\\n     6|import json, urllib.request, time, os, sys\\n     7|from PIL import Image, ImageDraw, ImageFont\\n     8|\\n     9|# Konfiguration\\n    10|COMFY_URL = \\\"http://127.0.0.1:8188\\\"\\n    11|OUTPUT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), \\\"..\\\", \\\"images\\\"))\\n    12|os.makedirs(OUTPUT_DIR, exist_ok=True)\\n    13|\\n    14|# Artikel-Definitionen\\n    15|ARTICLES = [\\n    16|    {\\n    17|        \\\"slug\\\": \\\"vps-absichern-2026\\\",\\n    18|        \\\"title\\\": \\\"VPS absichern 2026\\\",\\n    19|        \\\"category\\\": \\\"devops\\\",\\n    20|        \\\"color\\\": \\\"#FF9800\\\",\\n    21|        \\\"icon_prompt\\\": \\\"a shield with a lock inside, flat bold vector icon, white silhouette, minimalist, centered on dark background, security symbol, no details, clean shape\\\"\\n    22|    },\\n    23|    {\\n    24|        \\\"slug\\\": \\\"docker-compose-vps-guide\\\",\\n    25|        \\\"title\\\": \\\"Docker Compose auf dem VPS\\\",\\n    26|        \\\"category\\\": \\\"devops\\\",\\n    27|        \\\"color\\\": \\\"#FF9800\\\",\\n    28|        \\\"icon_prompt\\\": \\\"three stacked server boxes or containers, flat bold vector icon, white silhouette, minimalist, centered on dark background, docker style, no details\\\"\\n    29|    },\\n    30|    {\\n    31|        \\\"slug\\\": \\\"valheim-server-vps-mieten-2026\\\",\\n    32|        \\\"title\\\": \\\"Valheim Server mieten\\\",\\n    33|        \\\"category\\\": \\\"gaming\\\",\\n    34|        \\\"color\\\": \\\"#4CAF50\\\",\\n    35|        \\\"icon_prompt\\\": \\\"a viking helmet with horns, flat bold vector icon, white silhouette, minimalist, centered on dark background, norse symbol, no details\\\"\\n    36|    },\\n    37|    {\\n    38|        \\\"slug\\\": \\\"webhosting-anbieter-vergleich-2026\\\",\\n    39|        \\\"title\\\": \\\"Webhosting-Anbieter 2026\\\",\\n    40|        \\\"category\\\": \\\"webhosting\\\",\\n    41|        \\\"color\\\": \\\"#2196F3\\\",\\n    42|        \\\"icon_prompt\\\": \\\"a globe or world wide web symbol, flat bold vector icon, white silhouette, minimalist, centered on dark background, internet, clean shape\\\"\\n    43|    },\\n    44|    {\\n    45|        \\\"slug\\\": \\\"minecraft-server-vergleich-2026\\\",\\n    46|        \\\"title\\\": \\\"Minecraft Server\\\",\\n    47|        \\\"category\\\": \\\"gaming\\\",\\n    48|        \\\"color\\\": \\\"#4CAF50\\\",\\n    49|        \\\"icon_prompt\\\": \\\"a pickaxe crossed with a sword, flat bold vector icon, white silhouette, minimalist, centered on dark background, minecraft style, no details\\\"\\n    50|    },\\n    51|    {\\n    52|        \\\"slug\\\": \\\"gameserver-mieten-guide\\\",\\n    53|        \\\"title\\\": \\\"Gameserver mieten\\\",\\n    54|        \\\"category\\\": \\\"gaming\\\",\\n    55|        \\\"color\\\": \\\"#4CAF50\\\",\\n    56|        \\\"icon_prompt\\\": \\\"a game controller or gamepad, flat bold vector icon, white silhouette, minimalist, centered on dark background, gaming symbol, no details\\\"\\n    57|    },\\n    58|    {\\n    59|        \\\"slug\\\": \\\"webhosting-vserver-vergleich\\\",\\n    60|        \\\"title\\\": \\\"Webhosting vs VServer\\\",\\n    61|        \\\"category\\\": \\\"webhosting\\\",\\n    62|        \\\"color\\\": \\\"#2196F3\\\",\\n    63|        \\\"icon_prompt\\\": \\\"a balance scale or two servers side by side, flat bold vector icon, white silhouette, minimalist, centered on dark background, comparison symbol\\\"\\n    64|    },\\n    65|    {\\n    66|        \\\"slug\\\": \\\"devops-tools-2024\\\",\\n    67|        \\\"title\\\": \\\"DevOps Tools 2024\\\",\\n    68|        \\\"category\\\": \\\"devops\\\",\\n    69|        \\\"color\\\": \\\"#FF9800\\\",\\n    70|        \\\"icon_prompt\\\": \\\"a gear or wrench crossed with a terminal bracket, flat bold vector icon, white silhouette, minimalist, centered on dark background, tools symbol\\\"\\n    71|    },\\n    72|]\\n    73|\\n    74|CATEGORY_COLORS = {\\n    75|    \\\"gaming\\\": (\\\"#4CAF50\\\", \\\"#81C784\\\"),\\n    76|    \\\"webhosting\\\": (\\\"#2196F3\\\", \\\"#64B5F6\\\"),\\n  ",
