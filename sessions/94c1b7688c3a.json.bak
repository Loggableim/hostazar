      "name": "read_file",
      "content": "{\"content\": \"   205|def compose_poptech(icon_path, output_path, title_text, category):\\n   206|    \\\"\\\"\\\"Compose the final Pop-Tech Kacheln image with background, icon, and text.\\\"\\\"\\\"\\n   207|    # Size\\n   208|    W, H = 1200, 630\\n   209|\\n   210|    # Colors\\n   211|    if category in CATEGORY_COLORS:\\n   212|        left_color_hex, left_color_light = CATEGORY_COLORS[category]\\n   213|    else:\\n   214|        left_color_hex, left_color_light = \\\"#9C27B0\\\", \\\"#CE93D8\\\"\\n   215|    purple = \\\"#9C27B0\\\"\\n   216|    left_rgb = hex_to_rgb(left_color_hex)\\n   217|    purple_rgb = hex_to_rgb(purple)\\n   218|\\n   219|    # Create canvas\\n   220|    canvas = Image.new(\\\"RGB\\\", (W, H))\\n   221|    draw = ImageDraw.Draw(canvas)\\n   222|\\n   223|    # Fill left half with category color\\n   224|    draw.rectangle([(0, 0), (W // 2, H)], fill=left_rgb)\\n   225|    # Fill right half with purple\\n   226|    draw.rectangle([(W // 2, 0), (W, H)], fill=purple_rgb)\\n   227|\\n   228|    # Add a subtle diagonal overlap / transition line (like a zigzag or angled cut)\\n   229|    # Simple 5px white/light divider line at the center\\n   230|    for x_offset in range(-2, 3):\\n   231|        draw.line([(W // 2 + x_offset, 0), (W // 2 + x_offset, H)], fill=(255, 255, 255), width=1)\\n   232|\\n   233|    # Load and process icon\\n   234|    if os.path.exists(icon_path):\\n   235|        icon = Image.open(icon_path).convert(\\\"RGBA\\\")\\n   236|        # Scale icon to fit nicely\\n   237|        icon_size = 280  # max width/height for icon\\n   238|        icon.thumbnail((icon_size, icon_size), Image.LANCZOS)\\n   239|\\n   240|        # Create white silhouette from the icon\\n   241|        # Convert to grayscale, threshold to get the white shape\\n   242|        gray = icon.convert(\\\"L\\\")\\n   243|        # Create a mask where white/light pixels become opaque\\n   244|        mask = gray.point(lambda x: 255 if x > 100 else 0)\\n   245|        \\n   246|        # Create a white shape\\n   247|        white_shape = Image.new(\\\"RGBA\\\", icon.size, (255, 255, 255, 0))\\n   248|        white_shape.putalpha(mask)\\n   249|\\n   250|        # Paste icon centered\\n   251|        icon_x = (W - icon.size[0]) // 2\\n   252|        icon_y = (H - icon.size[1]) // 2 - 40  # offset up to leave room for text\\n   253|        canvas.paste(white_shape, (icon_x, icon_y), white_shape)\\n   254|\\n   255|    # Add text - title\\n   256|    title_text_short = title_text\\n   257|    # Try to find a font\\n   258|    font_paths = [\\n   259|        \\\"C:/Windows/Fonts/seguiemj.ttf\\\",  # Segoe UI Emoji\\n   260|        \\\"C:/Windows/Fonts/segoeuib.ttf\\\",  # Segoe UI Bold\\n   261|        \\\"C:/Windows/Fonts/segoeui.ttf\\\",   # Segoe UI\\n   262|        \\\"C:/Windows/Fonts/arialbd.ttf\\\",   # Arial Bold\\n   263|        \\\"C:/Windows/Fonts/arial.ttf\\\",     # Arial\\n   264|        \\\"/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf\\\",\\n   265|        \\\"/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf\\\",\\n   266|    ]\\n   267|    font = None\\n   268|    for fp in font_paths:\\n   269|        if os.path.exists(fp):\\n   270|            try:\\n   271|                font = ImageFont.truetype(fp, 32)\\n   272|                break\\n   273|            except Exception:\\n   274|                continue\\n   275|    if font is None:\\n   276|        font = ImageFont.load_default()\\n   277|\\n   278|    # Draw text centered below icon\\n   279|    bbox = draw.textbbox((0, 0), title_text_short, font=font)\\n   280|    tw = bbox[2] - bbox[0]\\n   281|    th = bbox[3] - bbox[1]\\n   282|    tx = (W - tw) // 2\\n   283|    ty = (H // 2) + 120  # below the icon area\\n   284|\\n   285|    # Text shadow for readability\\n   286|    draw.text((tx + 1, ty + 1), title_text_short, fill=(0, 0, 0, 100), font=font)\\n   287|    draw.text((tx, ty), title_text_short, fill=(255, 255, 255), font=font)\\n   288|\\n   289|    # Add category badge top-left\\n   290|    badge_text = category.upper()\\n   291|    bbox2 = draw.textbbox((0, 0), badge_text, font=font)\\n   292|    bw = bbox2[2] - bbox2[0]\\n   293|    badge_rect = (20, 20, 30 + bw, 46)\\n   294|    draw.rectangle(badge_rect, fill=left_rgb)\\n   295|    draw.text((25, 23), badge_text, fill=(255, 255, 255), font=font)\\n   296|\\n   297|    # Save\\n   298|    canvas.save(output_path, \\\"PNG\\\", quality=95)\\n   299|    print(f\\\"  Composed: {os.path.basename(output_path)}\\\")\\n   300|    return output_path\\n   301|\\n   302|def generate_icon_sdxl(icon_prompt, seed=None):\\n   303|    \\\"\\\"\\\"Generate just the icon as white silhouette on dark bg using SDXL.\\\"\\\"\\\"\\n   304|    prompt = f\\\"flat vector silhouette icon of {icon_prompt}, solid white shape on solid dark grey background #222222, no details inside the shape, bold clean outline, minimalist icon design, no text, no gradient, high contrast, centered composition\\\"\\n   305|    neg = \\\"text, watermark, signature, blurry, low quality, photorealistic, 3d, gradient, complex details, multiple objects, realistic, shadow\\\"\\n   306|    \\n   307|    workflow = {\\n   308|        \\\"1\\\": {\\\"class_type\\\": \\\"CheckpointLoaderSimple\\\", \\\"inputs\\\": {\\\"ckpt_name\\\": \\\"sd_xl_base_1.0.safetensors\\\"}},\\n   309|        \\\"2\\\": {\\\"class_type\\\": \\\"CLIPTextEncode\\\", \\\"inputs\\\": {\\\"text\\\": prompt, \\\"clip\\\": [\\\"1\\\", 1]}},\\n   310|        \\\"3\\\": {\\\"class_type\\\": \\\"CLIPTextEncode\\\", \\\"inputs\\\": {\\\"text\\\": neg, \\\"clip\\\": [\\\"1\\\", 1]}},\\n   311|        \\\"4\\\": {\\\"class_type\\\": \\\"EmptyLatentImage\\\", \\\"inputs\\\": {\\\"width\\\": 1024, \\\"height\\\": 1024, \\\"batch_size\\\": 1}},\\n   312|        \\\"5\\\": {\\\"class_type\\\": \\\"KSampler\\\", \\\"inputs\\\": {\\n   313|            \\\"seed\\\": seed if seed else 42,\\n   314|            \\\"control_after_generate\\\": \\\"randomize\\\",\\n   315|            \\\"steps\\\": 25, \\\"cfg\\\": 7.0, \\\"sampler_name\\\": \\\"dpmpp_2m\\\", \\\"scheduler\\\": \\\"karras\\\",\\n   316|            \\\"denoise\\\": 1.0, \\\"model\\\": [\\\"1\\\", 0], \\\"positive\\\": [\\\"2\\\", 0],\\n   317|            \\\"negative\\\": [\\\"3\\\", 0], \\\"latent_image\\\": [\\\"4\\\", 0]\\n   318|        }},\\n   319|        \\\"6\\\": {\\\"class_type\\\": \\\"VAEDecode\\\", \\\"inputs\\\": {\\\"samples\\\": [\\\"5\\\", 0], \\\"vae\\\": [\\\"1\\\", 2]}},\\n   320|        \\\"7\\\": {\\\"class_type\\\": \\\"SaveImage\\\", \\\"inputs\\\": {\\\"filename_prefix\\\": \\\"icon_temp\\\", \\\"images\\\": [\\\"6\\\", 0]}}\\n   321|    }\\n   322|    \\n   323|    payload = json.dumps({\\\"prompt\\\": workflow, \\\"client_id\\\": \\\"hostazar-icons\\\"}).encode()\\n   324|    req = urllib.request.Request(f\\\"{COMFY_URL}/prompt\\\", data=payload, headers={\\\"Content-Type\\\": \\\"application/json\\\"})\\n   325|    resp = json.loads(urllib.request.urlopen(req).read())\\n   326|    pid = resp[\\\"prompt_id\\\"]\\n   327|    print(f\\\"  Icon prompt: {pid}\\\")\\n   328|    return pid\\n   329|\\n   330|def main():\\n   331|    print(\\\"=== Pop-Tech Kacheln Batch Generator ===\\\\n\\\")\\n   332|    \\n   333|    # Step 1: Generate icons with SDXL\\n   334|    icon_files = {}\\n   335|    for art in ARTICLES:\\n   336|        slug = art[\\\"slug\\\"]\\n   337|        icon_path = os.path.join(OUTPUT_DIR, f\\\"icon_{slug}.png\\\")\\n   338|        if os.path.exists(icon_path) and os.path.getsize(icon_path) > 1000:\\n   339|            print(f\\\"  [SKIP] Icon exists for {slug}\\\")\\n   340|            icon_files[slug] = icon_path\\n   341|            continue\\n   342|        \\n   343|        print(f\\\"\\\\n[ICON] {slug} — {art['icon_prompt'][:60]}...\\\")\\n   344|        pid = generate_icon_sdxl(art[\\\"icon_prompt\\\"])\\n   345|        hist = poll_history(pid)\\n   346|        if hist:\\n   347|            fn, sub = get_latest_output(hist)\\n   348|            if fn:\\n   349|                downloaded = download_image(fn, sub, icon_path)\\n   350|                print(f\\\"  Saved icon: {downloaded}\\\")\\n   351|                icon_files[slug] = icon_path\\n   352|        # Small delay between prompts\\n   353|        time.sleep(2)\\n   354|    \\n   355|    # Step 2: Compose final images\\n   356|    print(\\\"\\\\n=== Composing final images ===\\\\n\\\")\\n   357|    for art in ARTICLES:\\n   358|        slug = art[\\\"slug\\\"]\\n   359|        output_path = os.path.join(OUTPUT_DIR, f\\\"{slug}.png\\\")\\n   360|        if os.path.exists(output_path) and os.path.getsize(output_path) > 10000:\\n   361|            print(f\\\"  [SKIP] Final exists for {slug}\\\")\\n   362|            continue\\n   363|        \\n   364|        icon_path = icon_files.get(slug)\\n   365|        if icon_path and os.path.exists(icon_path):\\n   366|            print(f\\\"\\\\n[COMPOSE] {slug} — {art['title']}\\\")\\n   367|            compose_poptech(icon_path, output_path, art[\\\"title\\\"], art[\\\"category\\\"])\\n   368|        else:\\n   369|            print(f\\\"\\\\n[COMPOSE] {slug} — no icon, generating without it\\\")\\n   370|            # Generate without icon\\n   371|            W, H = 1200, 630\\n   372|            left_rgb = hex_to_rgb(ARTICLES[0][\\\"color\\\"])  # fallback\\n   373|            for a in ARTICLES:\\n   374|                if a[\\\"slug\\\"] == slug:\\n   375|                    if a[\\\"category\\\"] in CATEGORY_COLORS:\\n   376|                        left_rgb = hex_to_rgb(CATEGORY_COLORS[a[\\\"category\\\"]][0])\\n   377|                    break\\n   378|            purple_rgb = hex_to_rgb(\\\"#9C27B0\\\")\\n   379|            canvas = Image.new(\\\"RGB\\\", (W, H))\\n   380|            draw = ImageDraw.Draw(canvas)\\n   381|            draw.rectangle([(0, 0), (W // 2, H)], fill=left_rgb)\\n   382|            draw.rectangle([(W // 2, 0), (W, H)], fill=purple_rgb)\\n   383|            canvas.save(output_path, \\\"PNG\\\", quality=95)\\n   384|            print(f\\\"  Saved fallback: {os.path.basename(output_path)}\\\")\\n   385|    \\n   386|    print(\\\"\\\\n=== Done ===\\\")\\n   387|\\n   388|if __name__ == \\\"__main__\\\":\\n   389|    main()\\n   390|\", \"total_lines\": 389, \"file_size\": 15705, \"truncated\": false, \"is_binary\": false, \"is_image\": false}",
