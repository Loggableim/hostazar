            "arguments": "{\"command\":\"set -e\\ngit fetch origin\\nprintf '%s\\\\n' '--- ahead/behind ---'\\ngit rev-list --left-right --count HEAD...origin/main\\nprintf '%s\\\\n' '--- remote commits not local ---'\\ngit log --oneline --decorate --max-count=10 HEAD..origin/main\\nprintf '%s\\\\n' '--- remote changed files ---'\\ngit diff --name-only HEAD..origin/main\\nprintf '%s\\\\n' '--- local status ---'\\ngit status --short\",\"timeout\":120,\"workdir\":\"/c/HermesPortable/home/scripts/blog-automation/hostazar\"}"
