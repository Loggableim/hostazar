            "arguments": "{\"command\":\"python - <<'PY'\\nimport urllib.request\\nfor url in ['https://tech.palworldgame.com/','https://tech.palworldgame.com/server/']:\\n    try:\\n        with urllib.request.urlopen(url, timeout=15) as r:\\n            data=r.read(2000)\\n        print('URL',url,'OK',len(data),data[:120].decode('utf-8','ignore').replace('\\\\n',' '))\\n    except Exception as e:\\n        print('URL',url,'ERR',repr(e))\\nPY\",\"timeout\":60,\"workdir\":\"/c/HermesPortable/home/scripts/blog-automation/hostazar\"}"
