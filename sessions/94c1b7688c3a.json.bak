      "snippet": "{\"success\": true, \"diff\": \"--- a//c/HermesPortable/home/tmp/hostazar-palworld-work/sitemap.xml\\n+++ b//c/HermesPortable/home/tmp/hostazar-palworld-work/sitemap.xml\\n@@ -11,12 +11,19 @@\\n   </url>\\r\\n \\r\\n \\r\\n-  <url>\\r\\n-    <loc>https://hostazar.com/artikel/vps-absichern-2026.html</loc>\\r\\n-    <lastmod>2026-06-02</lastmod>\\r\\n-    <changefreq>monthly</changefreq>\\r\\n-    <priority>0.9</priority>\\r\\n-  </url>\\r\\n+  <url>\\n+    <loc>https://hostazar.com/artikel/palworld-server-hosting-guide-2026.html</loc>\\n+    <lastmod>2026-06-15</lastmod>\\n+    <changefreq>monthly</changefreq>\\n+    <priority>0.9</priority>\\n+  </url>\\n+\\n+  <url>\\n+    <loc>https://hostazar.com/artikel/vps-absichern-2026.html</loc>\\n+    <lastmod>2026-06-02</lastmod>\\n+    <changefreq>monthly</changefreq>\\n+    <priority>0.9</priority>\\n+  </url>\\n \\r\\n   <url>\\r\\n     <loc>https://hostazar.com/artikel/docker-compose-vps-guide.html</loc>\\r\\n\", \"files_modified\": [\"/c/HermesPortable/home/tmp/hostazar-palworld-work/sitemap.xml\"], \"lint\": {\"status\": \"skipped\", \"message\": \"No linter for .xml files\"}}",
